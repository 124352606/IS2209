# ---------------------------------------------------------------------------
# DeployHub — environment variable template
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in your own values.
# NEVER commit .env to version control.
# ---------------------------------------------------------------------------

# Flask runtime environment (development | production | testing)
FLASK_ENV=development

# Set to 1 to enable Flask debug mode (auto-reload, detailed error pages).
# MUST be 0 in production.
FLASK_DEBUG=0

# PostgreSQL connection string.
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
# Use 'db' as the host when running inside Docker Compose.
DATABASE_URL=postgresql://postgres.mdrqklwobdwtfvgvovxn:DeployHub2026@aws-1-eu-west-1.pooler.supabase.com:5432/postgres

# PostgreSQL credentials — used by docker-compose.yaml to initialise the db
# service. Must match the values in DATABASE_URL above.
POSTGRES_USER=deployhub
POSTGRES_PASSWORD=deployhub
POSTGRES_DB=deployhub

# CoinGecko public API base URL (no key required).
# Override only if you are using a private/mirror instance.
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# Application log level (DEBUG | INFO | WARNING | ERROR | CRITICAL)
LOG_LEVEL=INFO

# TCP port the application listens on.
PORT=5000

# Flask secret key — used for session signing. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key
